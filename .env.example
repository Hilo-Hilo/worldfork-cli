# Copy to .env and fill in values. Only the CLI-side variables live here.
# Backend deployment owns its own env (LLM keys, database URL, etc.).

# Where the WorldFork backend lives. WORLD_FORK_API_BASE wins over BACKEND_API_BASE.
WORLD_FORK_API_BASE=http://localhost:8003
# BACKEND_API_BASE=http://localhost:8003

# Optional: file path used by `worldfork set-key` (defaults to ./.env).
# WORLD_FORK_ENV_FILE=.env
